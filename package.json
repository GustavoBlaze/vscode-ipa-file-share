{
  "name": "ipa-file-share",
  "icon": "icon.png",
  "publisher": "gustavoblaze",
  "displayName": "IPA File Share",
  "description": "Easy way of sharing you signed IPA files",
  "license": "MIT",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GustavoBlaze/vscode-ipa-file-share"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ipa-file-share.start",
        "title": "IPA File Share"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ipa-file-share.start",
          "when": "resourceExtname == '.ipa'",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "IPA File Share Config",
      "properties": {
        "ipaFileShare.ngrokToken": {
          "type": "string",
          "default": "",
          "description": "Seu Authtoken do ngrok (pegue em dashboard.ngrok.com)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "npx @vscode/vsce@latest package" 
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/plist": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "adm-zip": "^0.5.17",
    "express": "^5.2.1",
    "plist": "^3.1.0",
    "qrcode": "^1.5.4"
  }
}
